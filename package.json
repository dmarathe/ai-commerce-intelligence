{
  "name": "ai-commerce-intelligence",
  "version": "1.0.0",
  "description": "AI-powered commerce intelligence system integrating multiple eCommerce APIs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:unit": "node testing/unit/test-text-parsing-utils.js",
    "test:integration": "node testing/integration/test-real-api.js",
    "test:api": "node testing/api/manual-test.js",
    "test:verification": "node testing/final-verification-test.js",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:api && npm run test:verification",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "build": "echo 'No build step required for Node.js'",
    "docker:build": "docker build -t ai-commerce-intelligence .",
    "docker:run": "docker run -p 3000:3000 ai-commerce-intelligence"
  },
  "keywords": [
    "ai",
    "commerce",
    "intelligence",
    "ecommerce",
    "recommendations",
    "api",
    "machine-learning"
  ],
  "author": "Learning Project",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "axios": "^1.6.2",
    "mongoose": "^8.0.3",
    "redis": "^4.6.11",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "csv-parser": "^3.0.0",
    "lodash": "^4.17.21",
    "natural": "^6.5.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/ai-commerce-intelligence.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/ai-commerce-intelligence/issues"
  },
  "homepage": "https://github.com/yourusername/ai-commerce-intelligence#readme"
}
