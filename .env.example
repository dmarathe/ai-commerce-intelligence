# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/ai_commerce_intelligence
SKIP_DB=false

# Amazon Product Advertising API
AMAZON_ACCESS_KEY=your_amazon_access_key_here
AMAZON_SECRET_KEY=your_amazon_secret_key_here
AMAZON_ASSOCIATE_TAG=your_associate_tag-20
AMAZON_MARKETPLACE=www.amazon.com
AMAZON_REGION=us-east-1

# eBay Finding API
EBAY_APP_ID=your_ebay_app_id_here
EBAY_CERT_ID=your_ebay_cert_id_here
EBAY_DEV_ID=your_ebay_dev_id_here
EBAY_TOKEN=your_ebay_token_here
EBAY_SANDBOX=true

# Walmart Product API
WALMART_API_KEY=your_walmart_api_key_here
WALMART_API_URL=https://api.walmart.com/v2

# Shopify (uses public search, no API key required)
# SHOPIFY_STORE_URL=your_store.myshopify.com
# SHOPIFY_ACCESS_TOKEN=your_shopify_access_token_here

# MCP Server Configuration (Optional)
BRAVE_API_KEY=your_brave_search_api_key_here

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRE=7d

AMAZON_API_KEY=your_amazon_api_key
AMAZON_SECRET_KEY=your_amazon_secret_key
AMAZON_ASSOCIATE_TAG=your_amazon_associate_tag

SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_PASSWORD=your_shopify_password
SHOPIFY_STORE_NAME=your_shopify_store_name

EBAY_APP_ID=your_ebay_app_id
EBAY_CERT_ID=your_ebay_cert_id
EBAY_DEV_ID=your_ebay_dev_id
EBAY_TOKEN=your_ebay_token

WALMART_API_KEY=your_walmart_api_key

# Google Analytics
GOOGLE_ANALYTICS_ID=your_ga_tracking_id

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Cache Configuration
CACHE_TTL=3600

# ML Model Configuration
MODEL_UPDATE_INTERVAL=3600000
RECOMMENDATION_BATCH_SIZE=100
